# Managed by this repo (infra/ansible/roles/monitoring-stack) — local
# edits are overwritten on the next reconcile pass.
global:
  scrape_interval: 15s

scrape_configs:
  - job_name: prometheus
    static_configs:
      - targets: ["localhost:9090"]

{% set tailnet_short_names = patroni_pg_hosts | default([]) | map('regex_replace', '\..*$', '') | list %}
  - job_name: node
    static_configs:
{% for target in monitoring_scrape_targets %}
{% if target | lower in tailnet_short_names %}
      # mDNS doesn't cross the network boundary between this host's
      # LAN and a roaming/NAT'd node (found live: MorePower.local
      # resolves fine on its own LAN but not from smallrevolt) —
      # prefer the tailnet address for any host that's actually on it.
      - targets: ["{{ target | lower }}.{{ tailscale_tailnet_domain }}:9100"]
        labels:
          instance: "{{ target }}"
{% else %}
      - targets: ["{{ target }}.local:9100"]
        labels:
          instance: "{{ target }}"
{% endif %}
{% endfor %}
{% for target in monitoring_cloud_scrape_targets %}
      - targets: ["{{ target.address }}"]
        labels:
          instance: "{{ target.name }}"
{% endfor %}

  # Reuses patroni_pg_hosts (group_vars/patroni_db_nodes/vars.yml)
  # rather than a separate hardcoded list — this host (monitoring_host)
  # is itself a patroni_db_nodes member, so the variable is already in
  # scope, and it stays correct automatically if cluster membership
  # changes (e.g. itsarevolution rejoining) instead of needing a
  # second place to update.
  - job_name: postgres
    static_configs:
{% for host in patroni_pg_hosts | default([]) %}
      - targets: ["{{ host }}:{{ postgres_exporter_port | default(9187) }}"]
        labels:
          instance: "{{ host.split('.')[0] }}"
{% endfor %}

  # Patroni's own REST API exposes a native /metrics endpoint (no
  # separate exporter needed) with patroni_primary/patroni_replica —
  # the actual source of truth for cluster role, more reliable than
  # inferring it from postgres_exporter's metric set.
  - job_name: patroni
    metrics_path: /metrics
    static_configs:
{% for host in patroni_pg_hosts | default([]) %}
      - targets: ["{{ host }}:{{ patroni_restapi_port | default(8008) }}"]
        labels:
          instance: "{{ host.split('.')[0] }}"
{% endfor %}

  - job_name: ledger-service
    static_configs:
{% for target in banking_app_scrape_targets %}
{% if target | lower in tailnet_short_names %}
      - targets: ["{{ target | lower }}.{{ tailscale_tailnet_domain }}:8000"]
        labels:
          instance: "{{ target }}"
{% else %}
      - targets: ["{{ target }}.local:8000"]
        labels:
          instance: "{{ target }}"
{% endif %}
{% endfor %}
