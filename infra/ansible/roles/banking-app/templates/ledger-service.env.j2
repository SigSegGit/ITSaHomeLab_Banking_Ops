# Managed by this repo (infra/ansible/roles/banking-app) — local edits
# are overwritten on the next reconcile pass. Contains a password:
# mode 0600, not committed (this file only exists rendered, on the
# host).
#
# Multi-host libpq DSN: host/port are comma-lists in the query string
# (not the netloc, which SQLAlchemy's URL parser doesn't accept commas
# in) — psycopg2/libpq itself tries each host in order and, combined
# with target_session_attrs=read-write, connects to whichever one is
# currently accepting writes. That's the actual primary-discovery
# mechanism: no separate proxy (HAProxy/pgbouncer) needed for this,
# and it keeps working across a Patroni failover without anyone having
# to change this file or point the app at a new host.
DATABASE_URL=postgresql+psycopg2://admin:{{ patroni_admin_password }}@/ledger?host={{ patroni_pg_hosts | join(',') }}&port={{ ([patroni_pg_port | string] * (patroni_pg_hosts | length)) | join(',') }}&target_session_attrs=read-write&sslmode=disable
